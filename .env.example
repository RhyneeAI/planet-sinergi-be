APP_NAME="Gudang Planet BE"
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost

DB_CONNECTION=sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Redis — untuk queue export & cache
# Shared hosting (unix socket):
# REDIS_CLIENT=phpredis
# REDIS_SCHEME=unix
# REDIS_PATH=/path/to/redis.sock
# REDIS_HOST=
# REDIS_PORT=0
# REDIS_PASSWORD=null
#
# VPS / local (tcp):
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=null

# Queue — ganti ke redis saat production
# QUEUE_CONNECTION=redis

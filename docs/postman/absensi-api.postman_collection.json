              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "reports", "attendance"],
              "query": [
                { "key": "date_from", "value": "", "disabled": true },
                { "key": "date_to", "value": "", "disabled": true },
                { "key": "sub_company_uuid", "value": "", "disabled": true },
                { "key": "employee_uuid", "value": "", "disabled": true },
                { "key": "per_page", "value": "15", "disabled": true }
              ]
            },
            "description": "Laporan absensi.\n\nRole: SUPERADMIN, OWNER, ADMIN, HRD."
          }
        },
        {
          "name": "Payroll Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/abs/reports/payroll",

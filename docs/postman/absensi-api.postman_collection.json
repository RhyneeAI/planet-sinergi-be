          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/abs/shifts",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "shifts"]
            },
            "description": "List shift kerja.\n\nRole: SUPERADMIN, OWNER, ADMIN, HRD."
          }
        }
      ]
    },
    {

{
  "info": {
    "name": "Gudang Planet — Custom Configuration",
    "description": "Collection untuk kelola Custom Configuration.\n\n**Base URL:** `{{base_url}}/api/v1/abs`\n\n**Auth:** Bearer token dari `POST /api/v1/login` (phone + password).\n\n**Demo credentials (company 1):**\n| Role | Phone | Password |\n|------|-------|----------|\n| ADMIN | 081122223333 | admin_gp |\n| HRD | 081976567086 | hrd_gp |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"081122223333\",\n  \"password\": \"admin_gp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Login sebagai ADMIN. Token otomatis disimpan ke collection variable `token`."
          }
        },
        {
          "name": "Login (HRD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"081976567086\",\n  \"password\": \"hrd_gp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Login sebagai HRD. Token otomatis disimpan ke collection variable `token`."
          }
        }
      ]
    },
    {
      "name": "Custom Configurations",
      "item": [
        {
          "name": "List All",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/abs/custom-configurations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "custom-configurations"]
            },
            "description": "Lihat semua konfigurasi.\n\nRole: SUPERADMIN, OWNER, ADMIN, HRD."
          }
        },
        {
          "name": "Show by Key",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/abs/custom-configurations/overtime_hourly_rate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "custom-configurations", "overtime_hourly_rate"]
            },
            "description": "Detail konfigurasi by key.\n404 jika key tidak ditemukan.\n\nRole: SUPERADMIN, OWNER, ADMIN, HRD."
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"overtime_hourly_rate\",\n  \"value\": \"30000\",\n  \"description\": \"Tarif lembur per jam (global)\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/abs/custom-configurations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "custom-configurations"]
            },
            "description": "Buat konfigurasi baru.\n`key`: lowercase + underscore saja (a-z, _).\n\nRole: SUPERADMIN, ADMIN, HRD."
          }
        },
        {
          "name": "Update by Key",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"overtime_hourly_rate\",\n  \"value\": \"35000\",\n  \"description\": \"Tarif lembur per jam (global) - updated\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/abs/custom-configurations/overtime_hourly_rate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "abs", "custom-configurations", "overtime_hourly_rate"]
            },
            "description": "Update value/description dari konfigurasi by key.\n404 jika key tidak ditemukan.\n\nRole: SUPERADMIN, ADMIN, HRD."
          }
        }
      ]
    }
  ]
}
